{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "nvml-mock Helm values",
  "description": "Schema for deployments/nvml-mock/helm/nvml-mock/values.yaml. Validated by Helm at install/upgrade time so typos like `mode: healhty` or `probability: 1.5` fail fast with an actionable error instead of silently coercing to healthy / out-of-range behavior at runtime.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "gpu": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "profile": {
          "type": "string",
          "description": "GPU profile name. The valid set is enforced by the template helper (which renders a friendly error pointing users at gpu.customConfig); we deliberately avoid a JSON-schema enum here so the helper can keep producing that actionable message instead of a generic schema rejection."
        },
        "count": {
          "description": "Number of GPUs to expose. Use an integer to force a slice, or the empty string \"\" (default) to derive the count from the selected profile's devices list.",
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 64
            },
            {
              "type": "string",
              "enum": [""]
            }
          ]
        },
        "customConfig": {
          "type": "string"
        },
        "dynamicMetrics": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "seed": { "type": "integer" },
            "temperature": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "base_c": { "type": "integer", "minimum": 0, "maximum": 150 },
                "variance_c": { "type": "integer", "minimum": 0 },
                "ramp_c": { "type": "integer" },
                "ramp_period_sec": { "type": "integer", "minimum": 1 }
              }
            },
            "power": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "base_mw": { "type": "integer", "minimum": 0 },
                "variance_mw": { "type": "integer", "minimum": 0 }
              }
            },
            "utilization": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "pattern": {
                  "type": "string",
                  "enum": ["idle", "busy", "burst", "steady"]
                },
                "gpu_min": { "type": "integer", "minimum": 0, "maximum": 100 },
                "gpu_max": { "type": "integer", "minimum": 0, "maximum": 100 },
                "memory_min": { "type": "integer", "minimum": 0, "maximum": 100 },
                "memory_max": { "type": "integer", "minimum": 0, "maximum": 100 },
                "burst_period_sec": { "type": "integer", "minimum": 1 }
              }
            }
          }
        },
        "failureInjection": {
          "type": "object",
          "additionalProperties": true,
          "description": "Opt-in GPU failure scenarios. The engine treats `mode: healthy` as a no-op even when enabled, so a bare `enabled: true` does not silently trip every GPU.",
          "properties": {
            "enabled": { "type": "boolean" },
            "mode": {
              "type": "string",
              "description": "Failure mode. Anything outside this enum is rejected; the engine has no fall-through coercion path.",
              "enum": ["healthy", "lost", "fallen_off_bus", "ecc_uncorrectable"]
            },
            "probability": {
              "type": "number",
              "description": "Per-call trip probability. Must be in [0, 1]; 0 disables stochastic tripping.",
              "minimum": 0,
              "maximum": 1
            },
            "after_calls": {
              "type": "integer",
              "description": "Deterministic trip after N guarded NVML calls. 0 disables this trigger.",
              "minimum": 0
            },
            "seed": {
              "type": "integer",
              "description": "RNG seed for reproducibility. 0 means time-based (non-deterministic)."
            },
            "xid": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "code": {
                  "type": "integer",
                  "description": "Xid code surfaced via the NVML event set once the device trips. 0 disables Xid emission. Common codes: 79 (fallen off bus), 48 (DBE error), 63 (page retirement).",
                  "minimum": 0,
                  "maximum": 1023
                }
              }
            }
          }
        }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "driverVersion": { "type": "string" },
    "gpuOperator": {
      "type": "object",
      "additionalProperties": true,
      "description": "GPU Operator interoperability toggles.",
      "properties": {
        "driverSymlink": {
          "type": "object",
          "additionalProperties": true,
          "description": "Manage the /run/nvidia/driver -> /var/lib/nvml-mock/driver symlink used by the operator validator's mock branch. Disable for operator-managed driver mode.",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        }
      }
    },
    "hostDriver": {
      "type": "object",
      "additionalProperties": true,
      "description": "Host driver masquerade. When enabled, nvml-mock installs nvidia-smi and the mock libraries at the node's standard paths (/usr/bin, /usr/lib64 + ldconfig). MUTATES THE HOST — test nodes only. Never combine with an operator-managed driver DaemonSet.",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "resources": { "type": "object" },
    "nri": {
      "type": "object",
      "additionalProperties": true,
      "description": "Node-wide ambient injection via containerd NRI.",
      "properties": {
        "enabled": { "type": "boolean" },
        "socketPath": { "type": "string", "minLength": 1 },
        "pluginName": { "type": "string", "minLength": 1 },
        "pluginIndex": { "type": ["string", "integer"] },
        "image": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          }
        },
        "overlay": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "hostPath": { "type": "string", "minLength": 1 },
            "mountPath": { "type": "string", "minLength": 1 }
          }
        },
        "optOutAnnotation": { "type": "string", "minLength": 1 },
        "deviceAnnotation": { "type": "string", "minLength": 1 },
        "excludedNamespaces": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "resources": { "type": "object" }
      }
    },
    "terminationGracePeriodSeconds": {
      "type": "integer",
      "description": "Pod termination grace period (seconds). Lower values speed up rollouts; preStop cleanup is fast so 5-15s is typical.",
      "minimum": 0
    },
    "updateStrategy": {
      "type": "object",
      "additionalProperties": true,
      "description": "DaemonSet rolling update strategy passed verbatim into spec.updateStrategy.",
      "properties": {
        "type": { "type": "string", "enum": ["RollingUpdate", "OnDelete"] },
        "rollingUpdate": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "maxUnavailable": { "type": ["string", "integer"] },
            "maxSurge": { "type": ["string", "integer"] }
          }
        }
      }
    },
    "integrations": { "type": "object" },
    "fabricmanager": {
      "type": "object",
      "additionalProperties": true,
      "description": "Fake nvidia-fabricmanager daemon for NVSwitch platforms. When enabled is empty, the chart derives enablement from the GPU profile (NVSwitches or fabric.state: auto).",
      "properties": {
        "enabled": {
          "description": "Tri-state override: empty string derives from profile; true/false force the daemon on or off.",
          "oneOf": [
            { "type": "boolean" },
            { "type": "string", "enum": ["", "true", "false"] }
          ]
        },
        "stateDir": {
          "type": "string",
          "description": "HostPath directory for the node-local fabricmanager readiness marker."
        }
      }
    },
    "infiniband": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "ping": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "port": {
              "type": "integer",
              "description": "TCP port for the mock-ib fabric relay between nvml-mock pods.",
              "minimum": 1,
              "maximum": 65535
            },
            "networkPolicy": {
              "type": "object",
              "additionalProperties": true,
              "description": "NetworkPolicy restricting inbound access to the fabric port to peer nvml-mock pods. No-op on CNIs that do not enforce NetworkPolicy (e.g. Kind's kindnet).",
              "properties": {
                "enabled": { "type": "boolean" }
              }
            }
          }
        }
      }
    }
  }
}
