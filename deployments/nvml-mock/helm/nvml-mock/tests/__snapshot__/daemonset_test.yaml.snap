should match snapshot with all overrides:
  1: |
    apiVersion: apps/v1
    kind: DaemonSet
    metadata:
      labels:
        app.kubernetes.io/component: daemon
        app.kubernetes.io/instance: custom
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: nvml-mock
        app.kubernetes.io/version: 550.163.01
        helm.sh/chart: nvml-mock-0.2.1
      name: nvml-mock-custom
    spec:
      selector:
        matchLabels:
          app.kubernetes.io/instance: custom
          app.kubernetes.io/name: nvml-mock
      template:
        metadata:
          annotations:
            checksum/config: 55bb2f5a4208bf44b344cc0227800acef90b155558045d62d3f2bbf1c55b2184
          labels:
            app.kubernetes.io/component: daemon
            app.kubernetes.io/instance: custom
            app.kubernetes.io/name: nvml-mock
        spec:
          containers:
            - command:
                - /scripts/entrypoint.sh
              env:
                - name: GPU_COUNT
                  value: "2"
                - name: DRIVER_VERSION
                  value: 555.55.55
                - name: NODE_NAME
                  valueFrom:
                    fieldRef:
                      fieldPath: spec.nodeName
                - name: MOCK_NVML_CONFIG
                  value: /etc/nvml-mock/config.yaml
                - name: MOCK_FABRICMANAGER
                  value: "on"
                - name: MOCK_FABRICMANAGER_STATE_DIR
                  value: /var/lib/nvml-mock/fabric-state
                - name: MOCK_IB
                  value: full
                - name: MOCK_IB_PING_FABRIC
                  value: "1"
                - name: MOCK_IB_PING_PORT
                  value: "18515"
                - name: MOCK_IB_PING_SOCKET
                  value: /var/lib/nvml-mock/run/mock-ib.sock
                - name: POD_IP
                  valueFrom:
                    fieldRef:
                      fieldPath: status.podIP
                - name: MOCK_IB_PING_SERVICE_HOST
                  value: nvml-mock-custom-ibping.gpu-system.svc.cluster.local
                - name: LD_PRELOAD
                  value: /usr/local/lib/libibmockumad.so.1:/usr/local/lib/libibmockverbs.so.1:/usr/local/lib/libibmocksys.so.1:/usr/local/lib/libpcimocksys.so.1
                - name: MOCK_IB_ROOT
                  value: /var/lib/nvml-mock/ib
                - name: MOCK_PCI_ROOT
                  value: /var/lib/nvml-mock
              image: custom-registry/nvml-mock:v2.0.0
              imagePullPolicy: Always
              lifecycle:
                preStop:
                  exec:
                    command:
                      - /scripts/cleanup.sh
              name: nvml-mock
              ports:
                - containerPort: 18515
                  name: ibping
                  protocol: TCP
                - containerPort: 50000
                  name: imex
                  protocol: TCP
                - containerPort: 50005
                  name: imex-cmd
                  protocol: TCP
              resources:
                limits:
                  cpu: 500m
                  memory: 256Mi
                requests:
                  cpu: 100m
                  memory: 128Mi
              securityContext:
                privileged: true
              volumeMounts:
                - mountPath: /host/var/lib/nvml-mock
                  name: host-nvml-mock
                - mountPath: /var/lib/nvml-mock
                  name: host-nvml-mock
                - mountPath: /etc/nvml-mock
                  name: gpu-config
                - mountPath: /host/var/run/cdi
                  name: host-cdi
                - mountPath: /host/run/nvidia
                  name: host-run-nvidia
                - mountPath: /var/lib/nvml-mock/fabric-state
                  name: host-fabric-state
          nodeSelector:
            nvidia.com/gpu.present: "true"
          serviceAccountName: nvml-mock-custom
          terminationGracePeriodSeconds: 10
          tolerations:
            - effect: NoSchedule
              key: nvidia.com/gpu
              operator: Exists
          volumes:
            - hostPath:
                path: /var/lib/nvml-mock
                type: DirectoryOrCreate
              name: host-nvml-mock
            - configMap:
                name: nvml-mock-custom-config
              name: gpu-config
            - hostPath:
                path: /var/run/cdi
                type: DirectoryOrCreate
              name: host-cdi
            - hostPath:
                path: /run/nvidia
                type: DirectoryOrCreate
              name: host-run-nvidia
            - hostPath:
                path: /var/lib/nvml-mock/fabric-state
                type: DirectoryOrCreate
              name: host-fabric-state
      updateStrategy:
        rollingUpdate:
          maxUnavailable: 25%
        type: RollingUpdate
should match snapshot with b200 profile:
  1: |
    apiVersion: apps/v1
    kind: DaemonSet
    metadata:
      labels:
        app.kubernetes.io/component: daemon
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: nvml-mock
        app.kubernetes.io/version: 550.163.01
        helm.sh/chart: nvml-mock-0.2.1
      name: RELEASE-NAME-nvml-mock
    spec:
      selector:
        matchLabels:
          app.kubernetes.io/instance: RELEASE-NAME
          app.kubernetes.io/name: nvml-mock
      template:
        metadata:
          annotations:
            checksum/config: 3f424b3ca8461088c7b01c5753e4f75f59b7ed0bd48cb6875a4c7786d6b05a91
          labels:
            app.kubernetes.io/component: daemon
            app.kubernetes.io/instance: RELEASE-NAME
            app.kubernetes.io/name: nvml-mock
        spec:
          containers:
            - command:
                - /scripts/entrypoint.sh
              env:
                - name: GPU_COUNT
                  value: "4"
                - name: DRIVER_VERSION
                  value: 560.35.03
                - name: NODE_NAME
                  valueFrom:
                    fieldRef:
                      fieldPath: spec.nodeName
                - name: MOCK_NVML_CONFIG
                  value: /etc/nvml-mock/config.yaml
                - name: MOCK_IB
                  value: full
                - name: MOCK_IB_PING_FABRIC
                  value: "1"
                - name: MOCK_IB_PING_PORT
                  value: "18515"
                - name: MOCK_IB_PING_SOCKET
                  value: /var/lib/nvml-mock/run/mock-ib.sock
                - name: POD_IP
                  valueFrom:
                    fieldRef:
                      fieldPath: status.podIP
                - name: MOCK_IB_PING_SERVICE_HOST
                  value: RELEASE-NAME-nvml-mock-ibping.NAMESPACE.svc.cluster.local
                - name: LD_PRELOAD
                  value: /usr/local/lib/libibmockumad.so.1:/usr/local/lib/libibmockverbs.so.1:/usr/local/lib/libibmocksys.so.1:/usr/local/lib/libpcimocksys.so.1
                - name: MOCK_IB_ROOT
                  value: /var/lib/nvml-mock/ib
                - name: MOCK_PCI_ROOT
                  value: /var/lib/nvml-mock
              image: ghcr.io/nvidia/nvml-mock:latest
              imagePullPolicy: IfNotPresent
              lifecycle:
                preStop:
                  exec:
                    command:
                      - /scripts/cleanup.sh
              name: nvml-mock
              ports:
                - containerPort: 18515
                  name: ibping
                  protocol: TCP
                - containerPort: 50000
                  name: imex
                  protocol: TCP
                - containerPort: 50005
                  name: imex-cmd
                  protocol: TCP
              securityContext:
                privileged: true
              volumeMounts:
                - mountPath: /host/var/lib/nvml-mock
                  name: host-nvml-mock
                - mountPath: /var/lib/nvml-mock
                  name: host-nvml-mock
                - mountPath: /etc/nvml-mock
                  name: gpu-config
                - mountPath: /host/var/run/cdi
                  name: host-cdi
                - mountPath: /host/run/nvidia
                  name: host-run-nvidia
          serviceAccountName: RELEASE-NAME-nvml-mock
          terminationGracePeriodSeconds: 10
          tolerations:
            - operator: Exists
          volumes:
            - hostPath:
                path: /var/lib/nvml-mock
                type: DirectoryOrCreate
              name: host-nvml-mock
            - configMap:
                name: RELEASE-NAME-nvml-mock-config
              name: gpu-config
            - hostPath:
                path: /var/run/cdi
                type: DirectoryOrCreate
              name: host-cdi
            - hostPath:
                path: /run/nvidia
                type: DirectoryOrCreate
              name: host-run-nvidia
      updateStrategy:
        rollingUpdate:
          maxUnavailable: 25%
        type: RollingUpdate
