      name: RELEASE-NAME-nvml-mock
    spec:
      selector:
        matchLabels:
          app.kubernetes.io/instance: RELEASE-NAME
          app.kubernetes.io/name: nvml-mock
      template:
        metadata:
          annotations:
            checksum/config: 28998b50ef728ae5b194d8847eadc34fcc675e27fdf9f0bc2350a86e39473b9c
          labels:
            app.kubernetes.io/instance: RELEASE-NAME
            app.kubernetes.io/name: nvml-mock
