should match snapshot with all overrides:
  1: |
    apiVersion: apps/v1
    kind: DaemonSet
    metadata:
      labels:
        app.kubernetes.io/instance: custom
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: nvml-mock
        app.kubernetes.io/version: 550.163.01
        helm.sh/chart: nvml-mock-0.1.0
      name: nvml-mock-custom
    spec:
      selector:
        matchLabels:
          app.kubernetes.io/instance: custom
          app.kubernetes.io/name: nvml-mock
      template:
        metadata:
          annotations:
            checksum/config: a9dac7aa968f973518f4685fc2b41ca907c356337f88a38859184767ad1b4aa2
          labels:
            app.kubernetes.io/instance: custom
            app.kubernetes.io/name: nvml-mock
        spec:
          containers:
            - command:
                - /scripts/entrypoint.sh
              env:
                - name: GPU_COUNT
                  value: "2"
                - name: DRIVER_VERSION
                  value: 555.55.55
                - name: NODE_NAME
                  valueFrom:
                    fieldRef:
                      fieldPath: spec.nodeName
                - name: MOCK_NVML_CONFIG
                  value: /etc/nvml-mock/config.yaml
              image: custom-registry/nvml-mock:v2.0.0
              imagePullPolicy: Always
              lifecycle:
                preStop:
                  exec:
                    command:
                      - /scripts/cleanup.sh
              name: nvml-mock
              resources:
                limits:
                  cpu: 500m
                  memory: 256Mi
                requests:
                  cpu: 100m
                  memory: 128Mi
              securityContext:
                privileged: true
              volumeMounts:
                - mountPath: /host/var/lib/nvml-mock
                  name: host-nvml-mock
                - mountPath: /etc/nvml-mock
                  name: gpu-config
                - mountPath: /host/var/run/cdi
                  name: host-cdi
                - mountPath: /host/run/nvidia
                  name: host-run-nvidia
          nodeSelector:
            nvidia.com/gpu.present: "true"
          serviceAccountName: nvml-mock-custom
          tolerations:
            - effect: NoSchedule
              key: nvidia.com/gpu
              operator: Exists
          volumes:
            - hostPath:
                path: /var/lib/nvml-mock
                type: DirectoryOrCreate
              name: host-nvml-mock
            - configMap:
                name: nvml-mock-custom-config
              name: gpu-config
            - hostPath:
                path: /var/run/cdi
                type: DirectoryOrCreate
              name: host-cdi
            - hostPath:
                path: /run/nvidia
                type: DirectoryOrCreate
              name: host-run-nvidia
      updateStrategy:
        rollingUpdate:
          maxUnavailable: 100%
        type: RollingUpdate
