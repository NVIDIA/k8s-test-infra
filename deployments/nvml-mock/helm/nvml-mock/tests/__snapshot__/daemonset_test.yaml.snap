  1: |
    apiVersion: apps/v1
    kind: DaemonSet
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: nvml-mock
        app.kubernetes.io/version: 550.163.01
        helm.sh/chart: nvml-mock-0.1.0
      name: RELEASE-NAME-nvml-mock
    spec:
      selector:
        matchLabels:
          app.kubernetes.io/instance: RELEASE-NAME
          app.kubernetes.io/name: nvml-mock
      template:
        metadata:
          annotations:
            checksum/config: 39b4be468d3038181d5a5eb63fb5fba75f8ffa2500bc0cba20a308246a0334ca
          labels:
            app.kubernetes.io/instance: RELEASE-NAME
            app.kubernetes.io/name: nvml-mock
        spec:
          containers:
            - command:
                - /scripts/entrypoint.sh
              env:
                - name: GPU_COUNT
                  value: "4"
                - name: DRIVER_VERSION
                  value: 560.35.03
                - name: NODE_NAME
                  valueFrom:
                    fieldRef:
                      fieldPath: spec.nodeName
                - name: MOCK_NVML_CONFIG
                  value: /etc/nvml-mock/config.yaml
                - name: MOCK_IB
                  value: "1"
                - name: MOCK_IB_PING_FABRIC
                  value: "1"
                - name: MOCK_IB_PING_PORT
                  value: "18515"
                - name: POD_IP
                  valueFrom:
                    fieldRef:
                      fieldPath: status.podIP
                - name: MOCK_IB_PING_SERVICE_HOST
                  value: RELEASE-NAME-nvml-mock-ibping.NAMESPACE.svc.cluster.local
                - name: LD_PRELOAD
                  value: /usr/local/lib/libibmockumad.so.1:/usr/local/lib/libibmockverbs.so.1:/usr/local/lib/libibmocksys.so.1
                - name: MOCK_IB_ROOT
                  value: /var/lib/nvml-mock/ib
              image: ghcr.io/nvidia/nvml-mock:latest
              imagePullPolicy: IfNotPresent
              lifecycle:
                preStop:
                  exec:
                    command:
                      - /scripts/cleanup.sh
              name: nvml-mock
              ports:
                - containerPort: 18515
                  name: ibping
                  protocol: TCP
              securityContext:
                privileged: true
              volumeMounts:
                - mountPath: /host/var/lib/nvml-mock
                  name: host-nvml-mock
                - mountPath: /var/lib/nvml-mock
                  name: host-nvml-mock
                - mountPath: /etc/nvml-mock
                  name: gpu-config
                - mountPath: /host/var/run/cdi
                  name: host-cdi
                - mountPath: /host/run/nvidia
                  name: host-run-nvidia
          serviceAccountName: RELEASE-NAME-nvml-mock
          terminationGracePeriodSeconds: 10
          tolerations:
            - operator: Exists
          volumes:
            - hostPath:
                path: /var/lib/nvml-mock
                type: DirectoryOrCreate
              name: host-nvml-mock
            - configMap:
                name: RELEASE-NAME-nvml-mock-config
              name: gpu-config
            - hostPath:
                path: /var/run/cdi
                type: DirectoryOrCreate
              name: host-cdi
            - hostPath:
                path: /run/nvidia
                type: DirectoryOrCreate
              name: host-run-nvidia
      updateStrategy:
        rollingUpdate:
          maxUnavailable: 25%
        type: RollingUpdate
