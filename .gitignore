.idea

# Build artifacts
*.so
*.dll
*.dylib
*.out
*.test

# E2E harness failure diagnostics (E2E_ARTIFACTS default). The Ginkgo suite runs
# from tests/e2e/go, so the relative artifacts/e2e/go default resolves there.
e2e.log
tests/e2e/go/artifacts/

# Local Go build/test cache (the README's focused-test recipes point GOCACHE here)
.cache/

pkg/network/*/libibmock*
# Stray binaries from `go build ./cmd/...` at repo root
/check-fabric
/mock-ib

# Agentic working artifacts
.agents/
AGENTS.md
docs/plans/
docs/superpowers/
docs/magi/
.worktrees/
.spike-dcgm/

# mock-driver stub kernel module build artifacts (built host-side for CI or
# locally; generated header baked with the profile driver version)
deployments/mock-driver/kmod/stub_version.h
deployments/mock-driver/kmod/*.ko
